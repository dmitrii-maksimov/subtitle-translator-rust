{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SubtitleTranslator",
  "version": "2.0.2",
  "identifier": "com.dmitriimaksimov.subtitletranslator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Subtitle Translator",
        "width": 900,
        "height": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "nsis",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dmitrii-maksimov/subtitle-translator-rust/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1Q0YyMzQ1OTU0M0I5QTMKUldTanVVT1ZSU1BQVlFBbkxjejZObFgxQURnbjh2MVFhYVBaaU1TT295bkJ5ZVk2SnhvaExpTkcK"
    }
  }
}
